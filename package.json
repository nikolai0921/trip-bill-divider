{
  "name": "trip-bill-divider",
  "version": "0.1.0",
  "private": true,
  "description": "輕量版生活費用分攤器，支援 PWA 與 Capacitor 手機 App 打包。",
  "type": "module",
  "scripts": {
    "serve": "npx http-server . -p 4173 -c-1",
    "prepare:capacitor": "node scripts/prepare-capacitor.mjs",
    "cap:init": "npx cap init",
    "cap:add:android": "npm run prepare:capacitor && npx cap add android",
    "cap:add:ios": "npm run prepare:capacitor && npx cap add ios",
    "cap:sync": "npm run prepare:capacitor && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "android:create-key": "powershell -ExecutionPolicy Bypass -File scripts/create-upload-keystore.ps1",
    "android:bundle": "powershell -ExecutionPolicy Bypass -File scripts/build-signed-aab.ps1"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "http-server": "^14.1.1"
  }
}
